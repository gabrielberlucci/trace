// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id            Int        @id @default(autoincrement())
  document      String     @unique
  typePerson    typePerson
  name          String
  birthdate     DateTime?
  phone         String?
  address       String?
  zipcode       String?
  addressNumber Int?
  complement    String?
  email         String?    @unique
  ie            String?    @unique
  active        Int        @default(1)
  city          City?      @relation(fields: [cityId], references: [id])
  cityId        Int?
  sale          Sale[]
}

model Supplier {
  id            Int        @id @default(autoincrement())
  document      String     @unique
  typePerson    typePerson @default(PJ) // IDK IF ITS NECESSARY, BUT MAYBE WILL BE BAYED FROM A GUY WITH CPF? WHY NOT.
  name          String
  phone         String?
  address       String?
  zipcode       String?
  addressNumber Int?
  complement    String?
  email         String?    @unique
  ie            String?    @unique
  active        Int        @default(1)
  city          City?      @relation(fields: [cityId], references: [id])
  cityId        Int?
  products      Product[]
}

model Product {
  id           Int             @id @default(autoincrement())
  description  String
  barcode      String
  unity        Unity
  currentStock Float           @default(0)
  costPrice    Decimal         @db.Decimal(9, 2)
  salePrice    Decimal         @db.Decimal(9, 2)
  supplier     Supplier?       @relation(fields: [supplierId], references: [id])
  supplierId   Int?
  movement     StockMovement[]
  item         SaleItem[]
}

model StockMovement {
  id           Int      @id @default(autoincrement())
  quantity     Float // REMEMBER IT CAN BE METERS OF SOMETHING
  date         DateTime @default(now())
  typeMovement Movement

  products   Product   @relation(fields: [productsId], references: [id])
  productsId Int
  saleItem   SaleItem? @relation(fields: [saleItemId], references: [id])
  saleItemId Int?
}

model City {
  id        Int        @id // come from API SEED
  name      String
  state     String
  customers Customer[]
  suppliers Supplier[]
  users     User[]
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  birthdate     DateTime?
  phone         String?
  address       String?
  zipcode       String?
  addressNumber Int?
  complement    String?
  email         String?   @unique
  role          Role
  city          City?     @relation(fields: [cityId], references: [id])
  cityId        Int
}

model Sale {
  id         Int        @id @default(autoincrement())
  saleItem   SaleItem[]
  customer   Customer   @relation(fields: [customerId], references: [id])
  customerId Int
}

model SaleItem {
  id          Int             @id @default(autoincrement())
  description String
  barcode     String
  quantity    Float // IT CAN BE METERS, MM OR SOMETHING LIKE THAT
  costPrice   Decimal
  salePrice   Decimal
  totalPrice  Decimal
  date        DateTime        @default(now())
  movement    StockMovement[]
  sale        Sale            @relation(fields: [saleId], references: [id])
  saleId      Int
  product     Product         @relation(fields: [productId], references: [id])
  productId   Int
}

// MAKE SERVICE MODEL

enum typePerson {
  PF
  PJ
}

enum Unity {
  UN
  CM
  MT
  MM
}

enum Role {
  ADMIN
  CAIXA
}

enum Movement {
  VENDAS
  SERVICO
  AJUSTE
  PERDA
}
